<div
    id="ui-identifier"
    class="button-group"
    role="radiogroup"
    aria-label="User Role Selection"
    data-testid="role-radio-group">

    <label class="radio-option" data-testid="role-admin-label">
        <input
            type="radio"
            name="userRole"
            value="Admin"
            data-testid="role-admin">
        Admin
    </label>

    <label class="radio-option" data-testid="role-manager-label">
        <input
            type="radio"
            name="userRole"
            value="Manager"
            data-testid="role-manager">
        Manager
    </label>

    <label class="radio-option" data-testid="role-test-data-user-label">
        <input
            type="radio"
            name="userRole"
            value="Premium test-data User"
            data-testid="role-test-data-user">
        Premium test-data User
    </label>

    <label class="radio-option" data-testid="role-guest-label">
        <input
            type="radio"
            name="userRole"
            value="Guest"
            data-testid="role-guest">
        Guest
    </label>

</div>
